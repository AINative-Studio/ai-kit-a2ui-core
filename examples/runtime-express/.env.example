# OpenAI
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/a2ui

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Server
PORT=3001
NODE_ENV=development

# Optional: Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Email (Optional - for sendEmail action)
RESEND_API_KEY=re_...
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
