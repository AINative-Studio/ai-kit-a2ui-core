{
  "manifest_version": 3,
  "name": "A2UI Inspector",
  "version": "1.0.0",
  "description": "DevTools extension for debugging and inspecting A2UI protocol communications",
  "permissions": [
    "storage",
    "devtools"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "extension/devtools.html",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "extension/icons/icon-16.png",
    "48": "extension/icons/icon-48.png",
    "128": "extension/icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
